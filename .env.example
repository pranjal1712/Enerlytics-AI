# --- Enerlytics AI Environment Variables Template ---
# Copy this file to .env and fill in the values

# Security (CRITICAL)
SECRET_KEY=your_long_random_alphanumeric_string_here

# LLM Providers (API Keys)
GROQ_API_KEY=gsk_your_groq_api_key
OPENAI_API_KEY=sk-your_openai_api_key (Optional: for alternate embeddings)

# Databases
QDRANT_URL=https://your-qdrant-cluster-url.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
REDIS_URL=redis://default:password@your-redis-instance:port

# Frontend Authentication
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# System Settings
PORT=8000
DEBUG=False
